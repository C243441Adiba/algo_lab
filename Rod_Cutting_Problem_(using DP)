#include <stdio.h>
int max(int a, int b)
{
    return (a > b) ? a : b;
}
int main()
{
    int n;
    printf("Enter rod length: ");
    scanf("%d", &n);
    int price[n];
    printf("Enter prices for each length (1 to n):\n");
    for(int i = 0; i < n; i++)
        scanf("%d", &price[i]);
    int dp[n+1];
    dp[0] = 0;
    for(int i = 1; i <= n; i++)
    {
        int max_val = 0;
        for(int j = 0; j < i; j++)
        {
            max_val = max(max_val, price[j] + dp[i - j - 1]);
        }

        dp[i] = max_val;
    }
    printf("Maximum Profit = %d", dp[n]);
    return 0;
}
