#include <stdio.h>

void sort(float ratio[], int weight[], int profit[], int n)
{
    int i, j;
    for(i = 0; i < n-1; i++)
    {
        for(j = i+1; j < n; j++)
        {
            if(ratio[i] < ratio[j])
            {
                float temp = ratio[i];
                ratio[i] = ratio[j];
                ratio[j] = temp;

                int t = weight[i];
                weight[i] = weight[j];
                weight[j] = t;

                t = profit[i];
                profit[i] = profit[j];
                profit[j] = t;
            }
        }
    }
}

int main()
{
    int n, i;
    int weight[50], profit[50];
    float ratio[50];
    int capacity;
    float totalProfit = 0;

    printf("Enter number of items: ");
    scanf("%d", &n);

    printf("Enter weights:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &weight[i]);

    printf("Enter profits:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &profit[i]);

    printf("Enter knapsack capacity: ");
    scanf("%d", &capacity);

    for(i = 0; i < n; i++)
        ratio[i] = (float)profit[i] / weight[i];

    sort(ratio, weight, profit, n);

    for(i = 0; i < n; i++)
    {
        if(capacity >= weight[i])
        {
            totalProfit += profit[i];
            capacity -= weight[i];
        }
        else
        {
            totalProfit += ratio[i] * capacity;
            break;
        }
    }

    printf("Maximum Profit = %.2f", totalProfit);

    return 0;
}
