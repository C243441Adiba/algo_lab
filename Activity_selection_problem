#include <stdio.h>

void sort(int start[], int finish[], int n)
{
    int i, j, temp;
    for(i = 0; i < n-1; i++)
    {
        for(j = 0; j < n-i-1; j++)
        {
            if(finish[j] > finish[j+1])
            {
                temp = finish[j];
                finish[j] = finish[j+1];
                finish[j+1] = temp;

                temp = start[j];
                start[j] = start[j+1];
                start[j+1] = temp;
            }
        }
    }
}

int main()
{
    int start[100], finish[100];
    int n, i, j;

    printf("Enter number of activities: ");
    scanf("%d", &n);

    printf("Enter start times:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &start[i]);

    printf("Enter finish times:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &finish[i]);

    sort(start, finish, n);

    printf("Selected activities:\n");

    i = 0;
    printf("%d ", i);

    for(j = 1; j < n; j++)
    {
        if(start[j] >= finish[i])
        {
            printf("%d ", j);
            i = j;
        }
    }

    return 0;
}
